# flock — Caddy site config for flock.forgesworn.dev
#
# Caddy fetches and renews a Let's Encrypt certificate automatically. Access
# logging is explicitly discarded — the host captures no request logs or data,
# in keeping with flock's privacy promise. The only network calls the app makes
# are to the user-configured Nostr relay and (optionally) a map tile server.
#
# Install on the host (95.217.39.110) — additive conf.d drop-in; never touches the
# shared /etc/caddy/Caddyfile (which `import`s conf.d/*.Caddyfile). See docs/DEPLOY.md:
#   cat deploy/Caddyfile | ssh deploy@95.217.39.110 'sudo tee /etc/caddy/conf.d/flock.forgesworn.dev.Caddyfile'
#   ssh deploy@95.217.39.110 'sudo caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile && sudo systemctl reload caddy'

flock.forgesworn.dev {
	root * /var/www/flock
	encode zstd gzip
	file_server

	# Privacy: no access logs.
	log {
		output discard
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		X-Frame-Options DENY
		Permissions-Policy "geolocation=(self)"
		Cross-Origin-Opener-Policy same-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Allows: self; OSM/self tiles (img/connect https); any Nostr relay (wss);
		# maplibre web workers (blob); inline styles the app sets.
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; connect-src 'self' https: wss:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; base-uri 'self'; form-action 'self'"
	}

	# CORS for the native (Capacitor) APK: inside the shell the app's origin is
	# https://localhost (Android) / capacitor://localhost (iOS), so its calls to
	# the privacy proxies below are cross-origin. These routes proxy public,
	# credential-less services, so a wildcard is safe — it widens nothing (the
	# endpoints were always publicly reachable) and the privacy property lives in
	# the proxying itself, not in who may call it. `header_down` SETS the header,
	# so an upstream's own ACAO (OSM sends one) is replaced, never duplicated.
	@apiPreflight {
		method OPTIONS
		path /tiles/* /nominatim/* /overpass/* /api/extract
	}
	handle @apiPreflight {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Accept"
		header Access-Control-Max-Age "86400"
		respond "" 204
	}

	# Map tiles — reverse-proxied through this origin so the third-party tile CDN
	# only ever sees this server, never the user's IP + viewport (which is roughly
	# where the circle is). The user talks only to flock.forgesworn.dev, which they
	# already trust to serve the app — no new third party. Client-identifying
	# headers are stripped; a proper User-Agent is set for OSM's tile-usage policy;
	# a long max-age lets Cloudflare/browser cache so few requests reach OSM.
	handle_path /tiles/* {
		reverse_proxy https://tile.openstreetmap.org {
			header_up Host tile.openstreetmap.org
			header_up -Referer
			header_up -X-Forwarded-For
			header_up -X-Forwarded-Proto
			header_up -X-Forwarded-Host
			header_up User-Agent "flock/1.0 (+https://flock.forgesworn.dev)"
			header_down Cache-Control "public, max-age=604800"
			header_down Access-Control-Allow-Origin "*"
		}
	}

	# Nominatim geocoding — same treatment. The literal place-name query reaches
	# Nominatim from this server, not the user's IP. `no-store` keeps the query out
	# of any shared (Cloudflare) cache — geocoding is occasional and user-specific.
	handle_path /nominatim/* {
		reverse_proxy https://nominatim.openstreetmap.org {
			header_up Host nominatim.openstreetmap.org
			header_up -Referer
			header_up -X-Forwarded-For
			header_up -X-Forwarded-Proto
			header_up -X-Forwarded-Host
			header_up User-Agent "flock/1.0 (+https://flock.forgesworn.dev)"
			header_down Cache-Control "private, no-store"
			header_down Access-Control-Allow-Origin "*"
		}
	}

	# Overpass venue search (fair meeting point) — same treatment as Nominatim. Only
	# the search-area bounding box reaches Overpass, and from this server, never the
	# user's IP. `no-store` keeps the bbox POST body out of any shared cache. Venue
	# search is occasional (only when someone finds a meeting point), never continuous.
	handle_path /overpass/* {
		reverse_proxy https://overpass-api.de {
			header_up Host overpass-api.de
			header_up -Referer
			header_up -X-Forwarded-For
			header_up -X-Forwarded-Proto
			header_up -X-Forwarded-Host
			header_up User-Agent "flock/1.0 (+https://flock.forgesworn.dev)"
			header_down Cache-Control "private, no-store"
			header_down Access-Control-Allow-Origin "*"
		}
	}

	# Offline-basemap extract service (server/extract.mjs via flock-extract.service).
	# Clips a bbox from the Protomaps build server-side so the browser only ever talks
	# to this origin. `handle` (not handle_path) preserves the /api/extract path.
	handle /api/extract {
		reverse_proxy 127.0.0.1:8791 {
			header_down Access-Control-Allow-Origin "*"
		}
	}

	# Service worker must never be stale (so app updates land); hashed assets are immutable.
	@sw path /sw.js
	header @sw Cache-Control "no-cache"

	# Navigations (index.html) carry no content hash, so they must revalidate too —
	# otherwise the browser/SW can serve a stale HTML that pins old hashed assets
	# (this is what kept a broken map build live). Belt-and-braces with the SW.
	@html path / /index.html
	header @html Cache-Control "no-cache"

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Android APK download (get.html). Revalidate so an updated APK lands at once
	# (file_server's ETag/Last-Modified makes unchanged checks a cheap 304, not a
	# 30 MB redownload); explicit type so every device offers to install it.
	@apk path /downloads/*.apk
	header @apk Cache-Control "no-cache"
	header @apk Content-Type application/vnd.android.package-archive
}
