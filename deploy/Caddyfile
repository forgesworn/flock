# flock — Caddy site config for flock.forgesworn.dev
#
# Caddy fetches and renews a Let's Encrypt certificate automatically. Access
# logging is explicitly discarded — the host captures no request logs or data,
# in keeping with flock's privacy promise. The only network calls the app makes
# are to the user-configured Nostr relay and (optionally) a map tile server.
#
# Install on the host (95.217.39.110) — additive conf.d drop-in; never touches the
# shared /etc/caddy/Caddyfile (which `import`s conf.d/*.Caddyfile). See docs/DEPLOY.md:
#   cat deploy/Caddyfile | ssh deploy@95.217.39.110 'sudo tee /etc/caddy/conf.d/flock.forgesworn.dev.Caddyfile'
#   ssh deploy@95.217.39.110 'sudo caddy validate --config /etc/caddy/Caddyfile --adapter caddyfile && sudo systemctl reload caddy'

flock.forgesworn.dev {
	root * /var/www/flock
	encode zstd gzip
	file_server

	# Privacy: no access logs.
	log {
		output discard
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		X-Frame-Options DENY
		Permissions-Policy "geolocation=(self)"
		Cross-Origin-Opener-Policy same-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Allows: self; OSM/self tiles (img/connect https); any Nostr relay (wss);
		# maplibre web workers (blob); inline styles the app sets.
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; connect-src 'self' https: wss:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; base-uri 'self'; form-action 'self'"
	}

	# Service worker must never be stale (so app updates land); hashed assets are immutable.
	@sw path /sw.js
	header @sw Cache-Control "no-cache"

	# Navigations (index.html) carry no content hash, so they must revalidate too —
	# otherwise the browser/SW can serve a stale HTML that pins old hashed assets
	# (this is what kept a broken map build live). Belt-and-braces with the SW.
	@html path / /index.html
	header @html Cache-Control "no-cache"

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
}
