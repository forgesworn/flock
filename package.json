{
  "name": "@forgesworn/flock",
  "version": "0.0.0",
  "description": "Coercion-resistant family & friends safety and privacy-preserving location sharing. Built on canary-kit over Nostr.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./geofence": {
      "types": "./dist/geofence.d.ts",
      "import": "./dist/geofence.js"
    },
    "./noreport": {
      "types": "./dist/noreport.d.ts",
      "import": "./dist/noreport.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "import": "./dist/policy.js"
    },
    "./signals": {
      "types": "./dist/signals.d.ts",
      "import": "./dist/signals.js"
    },
    "./nightout": {
      "types": "./dist/nightout.d.ts",
      "import": "./dist/nightout.js"
    },
    "./checkin": {
      "types": "./dist/checkin.d.ts",
      "import": "./dist/checkin.js"
    },
    "./buzz": {
      "types": "./dist/buzz.d.ts",
      "import": "./dist/buzz.js"
    },
    "./allclear": {
      "types": "./dist/allclear.d.ts",
      "import": "./dist/allclear.js"
    },
    "./fences": {
      "types": "./dist/fences.d.ts",
      "import": "./dist/fences.js"
    },
    "./rendezvous": {
      "types": "./dist/rendezvous.d.ts",
      "import": "./dist/rendezvous.js"
    },
    "./disband": {
      "types": "./dist/disband.d.ts",
      "import": "./dist/disband.js"
    },
    "./offgrid": {
      "types": "./dist/offgrid.d.ts",
      "import": "./dist/offgrid.js"
    },
    "./spokenverify": {
      "types": "./dist/spokenverify.d.ts",
      "import": "./dist/spokenverify.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "dev": "vite",
    "build:app": "vite build",
    "build:spike": "vite build -c vite.spike.config.ts",
    "preview:app": "vite preview",
    "deploy": "sh deploy/deploy.sh"
  },
  "keywords": [
    "flock",
    "family-safety",
    "location-sharing",
    "geofence",
    "duress",
    "coercion-resistance",
    "nostr",
    "privacy",
    "canary-kit",
    "spoken-token"
  ],
  "author": "forgesworn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forgesworn/flock.git"
  },
  "bugs": {
    "url": "https://github.com/forgesworn/flock/issues"
  },
  "dependencies": {
    "canary-kit": "^2.10.0",
    "rendezvous-kit": "^1.21.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/fraunces": "^5.2.5",
    "@fontsource-variable/hanken-grotesk": "^5.2.5",
    "@playwright/test": "^1.61.1",
    "@protomaps/basemaps": "^5.7.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "geohash-kit": "^1.5.1",
    "maplibre-gl": "^5.20.2",
    "nostr-tools": "^2.23.3",
    "nsec-tree": "^1.5.1",
    "pmtiles": "^4.4.1",
    "qrcode-generator": "^2.0.4",
    "signet-login": "^0.11.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
