# Native (Capacitor) build — `npm run build:native` (vite --mode native).
#
# Inside the APK there is no same-origin server, so the privacy proxies point at
# the production host instead: Caddy serves the identical /tiles, /nominatim,
# /overpass and /api/extract routes (deploy/Caddyfile), preserving the same
# guarantee — OSM/Overpass/Nominatim see the host's IP, never the user's.
VITE_TILE_URL=https://flock.forgesworn.dev/tiles/{z}/{x}/{y}.png
VITE_NOMINATIM_URL=https://flock.forgesworn.dev/nominatim
VITE_OVERPASS_URL=https://flock.forgesworn.dev/overpass/api/interpreter
VITE_EXTRACT_URL=https://flock.forgesworn.dev/api/extract
